#!/usr/bin/env bash
set -euo pipefail

VERSION="0.2.0"
PROGNAME="${0##*/}"
SEP=""
KEEP_SEP="none"

usage() {
    cat <<EOF
Usage: $PROGNAME [-s SEP] [-k [MODE]] [-h] [-V] [FILE...]

Suppress repeated leading content in consecutive lines by replacing
matching prefixes with spaces, making differences easy to spot.

Options:
  -s SEP         Split lines by separator characters in SEP.
                 Each character in SEP is an independent separator.
                 Default: '' (empty = character-by-character comparison).
                 Supports escapes: \\t (tab), \\n (newline), \\\\ (backslash).
  -k, --keep-sep [MODE]
                 Control which separators stay visible in the blanked prefix.
                 MODE is one of:
                   n, none  — replace all separators with spaces (default without -k)
                   l, last  — keep only the last separator in the blanked prefix
                   a, all   — keep all separators in the blanked prefix
                 If -k is given without MODE, defaults to 'all'.
  -h, --help     Show this help message
  -V, --version  Show version

If no FILE is given, reads from stdin. Use - for explicit stdin.

Examples:
  ls /usr/local/bin | $PROGNAME
  $PROGNAME -s ',' data.csv
  $PROGNAME -s '/' -k /etc/paths
  $PROGNAME -s '/' -k last /etc/paths
  $PROGNAME -s \$'\\t' data.tsv
  $PROGNAME -s ':|' mixed.log
EOF
}

# Parse arguments
FILES=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--sep)
            if [[ $# -lt 2 ]]; then
                echo "$PROGNAME: option $1 requires an argument" >&2
                exit 1
            fi
            SEP="$2"; shift 2 ;;
        -k|--keep-sep)
            if [[ $# -ge 2 ]]; then
                case "$2" in
                    none|n) KEEP_SEP="none"; shift 2 ;;
                    last|l) KEEP_SEP="last"; shift 2 ;;
                    all|a)  KEEP_SEP="all";  shift 2 ;;
                    *)      KEEP_SEP="all";  shift ;;
                esac
            else
                KEEP_SEP="all"; shift
            fi
            ;;
        -h|--help) usage; exit 0 ;;
        -V|--version) echo "$PROGNAME $VERSION"; exit 0 ;;
        --) shift; FILES+=("$@"); break ;;
        -*) echo "$PROGNAME: unknown option: $1" >&2; usage >&2; exit 1 ;;
        *) FILES+=("$1"); shift ;;
    esac
done

# Default to stdin if no files given
if [[ ${#FILES[@]} -eq 0 ]]; then
    FILES=("-")
fi

# Feed all inputs to awk
feed_input() {
    for f in "${FILES[@]}"; do
        if [[ "$f" == "-" ]]; then
            cat
        else
            cat -- "$f"
        fi
    done
}

# Note: awk -v interprets escape sequences (\t → tab, \n → newline, \\ → \)
feed_input | LC_ALL=C awk -v sep="$SEP" -v keep_sep="$KEEP_SEP" '
BEGIN {
    for (_i = 0; _i < 256; _i++)
        _ord[sprintf("%c", _i)] = _i
}

function make_spaces(n,    fmt) {
    if (n <= 0) return ""
    fmt = "%" n "s"
    return sprintf(fmt, "")
}

function is_sep(ch) {
    return (sep != "" && index(sep, ch) > 0)
}

function is_wide_cp(cp) {
    if (cp >= 4352 && cp <= 4447) return 1
    if (cp >= 9001 && cp <= 9002) return 1
    if (cp >= 9728 && cp <= 10175) return 1
    if (cp >= 11088 && cp <= 11093) return 1
    if (cp >= 11904 && cp <= 12350) return 1
    if (cp >= 12352 && cp <= 42191) return 1
    if (cp >= 44032 && cp <= 55203) return 1
    if (cp >= 63744 && cp <= 64255) return 1
    if (cp >= 65040 && cp <= 65049) return 1
    if (cp >= 65072 && cp <= 65135) return 1
    if (cp >= 65281 && cp <= 65376) return 1
    if (cp >= 65504 && cp <= 65510) return 1
    if (cp >= 126976 && cp <= 130815) return 1
    if (cp >= 131072 && cp <= 194591) return 1
    return 0
}

function is_zero_width_cp(cp) {
    if (cp >= 768 && cp <= 879) return 1
    if (cp >= 65024 && cp <= 65039) return 1
    if (cp >= 8203 && cp <= 8207) return 1
    if (cp >= 8232 && cp <= 8239) return 1
    if (cp >= 8288 && cp <= 8297) return 1
    if (cp == 65279) return 1
    return 0
}

function display_width_of(str, n,    i, b, cp, w) {
    w = 0
    i = 1
    while (i <= n) {
        b = _ord[substr(str, i, 1)]
        if (b < 128) {
            w++
            i++
        } else if (b >= 240) {
            cp = (b - 240) * 262144 + \
                 (_ord[substr(str, i+1, 1)] - 128) * 4096 + \
                 (_ord[substr(str, i+2, 1)] - 128) * 64 + \
                 (_ord[substr(str, i+3, 1)] - 128)
            if (!is_zero_width_cp(cp)) w += 2
            i += 4
        } else if (b >= 224) {
            cp = (b - 224) * 4096 + \
                 (_ord[substr(str, i+1, 1)] - 128) * 64 + \
                 (_ord[substr(str, i+2, 1)] - 128)
            if (is_wide_cp(cp)) w += 2
            else if (!is_zero_width_cp(cp)) w++
            i += 3
        } else if (b >= 192) {
            w++
            i += 2
        } else {
            i++
        }
    }
    return w
}

function blank_keep_sep(str, n,    i, b, cp, result) {
    result = ""
    i = 1
    while (i <= n) {
        b = _ord[substr(str, i, 1)]
        if (b < 128) {
            if (is_sep(substr(str, i, 1)))
                result = result substr(str, i, 1)
            else
                result = result " "
            i++
        } else if (b >= 240) {
            cp = (b - 240) * 262144 + \
                 (_ord[substr(str, i+1, 1)] - 128) * 4096 + \
                 (_ord[substr(str, i+2, 1)] - 128) * 64 + \
                 (_ord[substr(str, i+3, 1)] - 128)
            if (!is_zero_width_cp(cp))
                result = result "  "
            i += 4
        } else if (b >= 224) {
            cp = (b - 224) * 4096 + \
                 (_ord[substr(str, i+1, 1)] - 128) * 64 + \
                 (_ord[substr(str, i+2, 1)] - 128)
            if (is_wide_cp(cp))
                result = result "  "
            else if (!is_zero_width_cp(cp))
                result = result " "
            i += 3
        } else if (b >= 192) {
            result = result " "
            i += 2
        } else {
            i++
        }
    }
    return result
}

function char_ditto(prev, curr,    len_p, len_c, min_len, i) {
    len_p = length(prev)
    len_c = length(curr)
    min_len = (len_p < len_c) ? len_p : len_c
    for (i = 1; i <= min_len; i++) {
        if (substr(curr, i, 1) != substr(prev, i, 1))
            return i - 1
    }
    return min_len
}

function sep_process(prev, curr,    len_p, len_c, i_p, i_c, tok_start_c, tok_p, tok_c, last_sep_c, result, i, ch) {
    len_p = length(prev)
    len_c = length(curr)
    i_p = 1; i_c = 1
    last_sep_c = 0

    while (1) {
        tok_start_c = i_c

        tok_p = ""
        while (i_p <= len_p && !is_sep(substr(prev, i_p, 1))) {
            tok_p = tok_p substr(prev, i_p, 1); i_p++
        }

        tok_c = ""
        while (i_c <= len_c && !is_sep(substr(curr, i_c, 1))) {
            tok_c = tok_c substr(curr, i_c, 1); i_c++
        }

        if (tok_p != tok_c) {
            if (keep_sep == "all")
                return blank_keep_sep(curr, tok_start_c - 1) substr(curr, tok_start_c)
            if (keep_sep == "last" && last_sep_c > 0)
                return make_spaces(display_width_of(curr, last_sep_c - 1)) substr(curr, last_sep_c)
            return make_spaces(display_width_of(curr, tok_start_c - 1)) substr(curr, tok_start_c)
        }

        if (i_p <= len_p && is_sep(substr(prev, i_p, 1)) && \
            i_c <= len_c && is_sep(substr(curr, i_c, 1))) {
            last_sep_c = i_c
            i_p++; i_c++
        } else {
            break
        }
    }

    if (keep_sep == "all")
        return blank_keep_sep(curr, i_c - 1) substr(curr, i_c)
    if (keep_sep == "last" && last_sep_c > 0)
        return make_spaces(display_width_of(curr, last_sep_c - 1)) substr(curr, last_sep_c, 1) make_spaces(display_width_of(curr, i_c - 1) - display_width_of(curr, last_sep_c)) substr(curr, i_c)
    return make_spaces(display_width_of(curr, i_c - 1)) substr(curr, i_c)
}

{
    if (NR == 1) {
        print
    } else {
        if (sep == "") {
            ditto_len = char_ditto(prev, $0)
            if (ditto_len <= 0)
                print
            else if (ditto_len >= length($0))
                print make_spaces(display_width_of($0, length($0)))
            else
                print make_spaces(display_width_of($0, ditto_len)) substr($0, ditto_len + 1)
        } else {
            print sep_process(prev, $0)
        }
    }
    prev = $0
}
'
