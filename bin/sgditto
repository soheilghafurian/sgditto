#!/usr/bin/env bash
set -euo pipefail

VERSION="0.2.0"
PROGNAME="${0##*/}"
SEP=""
KEEP_SEP=0

usage() {
    cat <<EOF
Usage: $PROGNAME [-s SEP] [-k] [-h] [-V] [FILE...]

Suppress repeated leading content in consecutive lines by replacing
matching prefixes with spaces, making differences easy to spot.

Options:
  -s SEP         Split lines by separator characters in SEP.
                 Each character in SEP is an independent separator.
                 Default: '' (empty = character-by-character comparison).
                 Supports escapes: \\t (tab), \\n (newline), \\\\ (backslash).
  -k, --keep-sep Keep separator characters visible in the blanked prefix.
                 By default, separators are replaced with spaces too.
  -h, --help     Show this help message
  -V, --version  Show version

If no FILE is given, reads from stdin. Use - for explicit stdin.

Examples:
  ls /usr/local/bin | $PROGNAME
  $PROGNAME -s ',' data.csv
  $PROGNAME -s '/' -k /etc/paths
  $PROGNAME -s \$'\\t' data.tsv
  $PROGNAME -s ':|' mixed.log
EOF
}

# Parse arguments
FILES=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--sep)
            if [[ $# -lt 2 ]]; then
                echo "$PROGNAME: option $1 requires an argument" >&2
                exit 1
            fi
            SEP="$2"; shift 2 ;;
        -k|--keep-sep) KEEP_SEP=1; shift ;;
        -h|--help) usage; exit 0 ;;
        -V|--version) echo "$PROGNAME $VERSION"; exit 0 ;;
        --) shift; FILES+=("$@"); break ;;
        -*) echo "$PROGNAME: unknown option: $1" >&2; usage >&2; exit 1 ;;
        *) FILES+=("$1"); shift ;;
    esac
done

# Default to stdin if no files given
if [[ ${#FILES[@]} -eq 0 ]]; then
    FILES=("-")
fi

# Feed all inputs to awk
feed_input() {
    for f in "${FILES[@]}"; do
        if [[ "$f" == "-" ]]; then
            cat
        else
            cat -- "$f"
        fi
    done
}

# Note: awk -v interprets escape sequences (\t → tab, \n → newline, \\ → \)
feed_input | awk -v sep="$SEP" -v keep_sep="$KEEP_SEP" '
function make_spaces(n,    fmt) {
    if (n <= 0) return ""
    fmt = "%" n "s"
    return sprintf(fmt, "")
}

function is_sep(ch) {
    return (sep != "" && index(sep, ch) > 0)
}

function char_ditto(prev, curr,    len_p, len_c, min_len, i) {
    len_p = length(prev)
    len_c = length(curr)
    min_len = (len_p < len_c) ? len_p : len_c
    for (i = 1; i <= min_len; i++) {
        if (substr(curr, i, 1) != substr(prev, i, 1))
            return i - 1
    }
    return min_len
}

function sep_process(prev, curr,    len_p, len_c, i_p, i_c, tok_start_c, tok_p, tok_c, result, i, ch) {
    len_p = length(prev)
    len_c = length(curr)
    i_p = 1; i_c = 1

    while (1) {
        tok_start_c = i_c

        # Extract token from prev (chars until separator or end)
        tok_p = ""
        while (i_p <= len_p && !is_sep(substr(prev, i_p, 1))) {
            tok_p = tok_p substr(prev, i_p, 1); i_p++
        }

        # Extract token from curr
        tok_c = ""
        while (i_c <= len_c && !is_sep(substr(curr, i_c, 1))) {
            tok_c = tok_c substr(curr, i_c, 1); i_c++
        }

        # Compare tokens
        if (tok_p != tok_c) {
            # Mismatch: output blanked prefix + rest of curr
            if (keep_sep) {
                result = ""
                for (i = 1; i < tok_start_c; i++) {
                    ch = substr(curr, i, 1)
                    result = result (is_sep(ch) ? ch : " ")
                }
                return result substr(curr, tok_start_c)
            }
            return make_spaces(tok_start_c - 1) substr(curr, tok_start_c)
        }

        # Tokens match — check for separators after them
        if (i_p <= len_p && is_sep(substr(prev, i_p, 1)) && \
            i_c <= len_c && is_sep(substr(curr, i_c, 1))) {
            # Both have a separator; consume it and continue
            i_p++; i_c++
        } else {
            # One or both exhausted, or no separator follows
            break
        }
    }

    # All compared tokens matched — blank the matched portion of curr
    if (keep_sep) {
        result = ""
        for (i = 1; i < i_c; i++) {
            ch = substr(curr, i, 1)
            result = result (is_sep(ch) ? ch : " ")
        }
        return result substr(curr, i_c)
    }
    return make_spaces(i_c - 1) substr(curr, i_c)
}

{
    if (NR == 1) {
        print
    } else {
        if (sep == "") {
            ditto_len = char_ditto(prev, $0)
            if (ditto_len <= 0)
                print
            else if (ditto_len >= length($0))
                print make_spaces(length($0))
            else
                print make_spaces(ditto_len) substr($0, ditto_len + 1)
        } else {
            print sep_process(prev, $0)
        }
    }
    prev = $0
}
'
